@using BlazorFrontend.Models

<div class="product-card h-100 d-flex flex-column">
    <div class="d-flex justify-content-between align-items-start mb-2">
        <span class="fw-bold fs-6">@Product.Name</span>
        <span class="badge @(Product.Stock > 10 ? "bg-success" : Product.Stock > 0 ? "bg-warning text-dark" : "bg-danger") ms-2 flex-shrink-0">
            @(Product.Stock > 0 ? $"{Product.Stock} left" : "Out of stock")
        </span>
    </div>
    <p class="text-muted small mb-3 flex-grow-1" style="line-height:1.5">@Product.Description</p>
    <div class="d-flex justify-content-between align-items-center pt-2 border-top">
        <span class="fw-bold text-primary" style="font-size:1.2rem">$@Product.Price.ToString("F2")</span>
        <small class="text-muted">📦 ID #@Product.Id</small>
    </div>
</div>

@code {
    [Parameter, EditorRequired]
    public ProductDto Product { get; set; } = new();
}
