@using BlazorFrontend.Models

<!-- COMPONENT RULE: NO API calls. Lists loaded by parent page and passed in via [Parameter]. -->

<div class="card border-0 shadow-sm mb-4" style="border-left:4px solid #0d6efd !important">
    <div class="card-header border-0 fw-semibold" style="background:#eff6ff; color:#1d4ed8">
        🧾 New Order
    </div>
    <div class="card-body">
        <div class="row g-3">
            <div class="col-md-4">
                <label class="form-label fw-semibold">Customer</label>
                <select class="form-select" @bind="model.CustomerId">
                    <option value="0">- Select customer -</option>
                    @foreach (var c in Customers)
                    {
                        <option value="@c.Id">@c.Name</option>
                    }
                </select>
            </div>
            <div class="col-md-4">
                <label class="form-label fw-semibold">Product</label>
                <select class="form-select" @bind="selectedProductId" @bind:after="RecalculateTotal">
                    <option value="0">- Select product -</option>
                    @foreach (var p in Products)
                    {
                        <option value="@p.Id">@p.Name ($@p.Price.ToString("F2"))</option>
                    }
                </select>
            </div>
            <div class="col-md-2">
                <label class="form-label fw-semibold">Quantity</label>
                <input type="number" class="form-control" @bind="model.Quantity"
                       @bind:after="RecalculateTotal" min="1" />
            </div>
            <div class="col-md-2">
                <label class="form-label fw-semibold">Total</label>
                <div class="input-group">
                    <span class="input-group-text">$</span>
                    <input class="form-control fw-bold text-success" value="@model.TotalPrice.ToString("F2")" readonly />
                </div>
            </div>
            <div class="col-12 d-flex gap-2">
                <button class="btn btn-primary px-4" @onclick="HandleSubmit" disabled="@IsSaving">
                    @(IsSaving ? "Placing..." : "🛒 Place Order")
                </button>
                <button class="btn btn-outline-secondary" @onclick="HandleCancel">Cancel</button>
            </div>
        </div>
        @if (!string.IsNullOrEmpty(ErrorMessage))
        {
            <div class="alert alert-danger d-flex align-items-center gap-2 mt-3">
                <span>❌</span><span>@ErrorMessage</span>
            </div>
        }
    </div>
</div>

@code {
    [Parameter] public List<Customer> Customers { get; set; } = new();
    [Parameter] public List<Product> Products { get; set; } = new();
    [Parameter] public EventCallback<CreateOrderRequest> OnSubmit { get; set; }
    [Parameter] public EventCallback OnCancel { get; set; }
    [Parameter] public bool IsSaving { get; set; }

    private CreateOrderRequest model = new() { Quantity = 1 };
    private int selectedProductId = 0;
    private string ErrorMessage = string.Empty;

    private void RecalculateTotal()
    {
        model.ProductId = selectedProductId;
        var product = Products.FirstOrDefault(p => p.Id == selectedProductId);
        if (product != null && model.Quantity > 0)
            model.TotalPrice = product.Price * model.Quantity;
    }

    private async Task HandleSubmit()
    {
        if (model.CustomerId == 0) { ErrorMessage = "Please select a customer."; return; }
        if (model.ProductId == 0)  { ErrorMessage = "Please select a product."; return; }
        if (model.Quantity < 1)    { ErrorMessage = "Quantity must be at least 1."; return; }
        ErrorMessage = string.Empty;
        // Hand off to parent page - this component does NOT call any API.
        await OnSubmit.InvokeAsync(model);
        model = new() { Quantity = 1 };
        selectedProductId = 0;
    }

    private async Task HandleCancel() => await OnCancel.InvokeAsync();
}
