@page "/products"
@inject BlazorFrontend.Services.ProductService ProductService
@using BlazorFrontend.Models
@using BlazorFrontend.Components

<PageTitle>Products</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h2 class="fw-bold mb-0" style="color:#0f172a">📦 Products</h2>
        <p class="text-muted small mb-0">Browse and manage your product catalog</p>
    </div>
    <button class="btn @(showForm ? "btn-outline-secondary" : "btn-primary") px-4" @onclick="ToggleForm">
        @(showForm ? "✕ Cancel" : "+ Add Product")
    </button>
</div>

@if (!string.IsNullOrEmpty(message))
{
    <div class="alert @(success ? "alert-success" : "alert-danger") alert-dismissible d-flex align-items-center gap-2 mb-4">
        <span>@(success ? "✅" : "❌")</span>
        <span>@message</span>
        <button type="button" class="btn-close ms-auto" @onclick="() => message = string.Empty"></button>
    </div>
}

@if (showForm)
{
    <div class="card shadow-sm border-0 mb-4" style="border-left:4px solid #0d6efd !important">
        <div class="card-header border-0 fw-semibold" style="background:#eff6ff; color:#1d4ed8">
            📝 New Product
        </div>
        <div class="card-body">
            <div class="row g-3">
                <div class="col-md-6">
                    <label class="form-label fw-semibold">Name</label>
                    <input class="form-control" @bind="newProduct.Name" placeholder="e.g. Wireless Headphones" />
                </div>
                <div class="col-md-6">
                    <label class="form-label fw-semibold">Description</label>
                    <input class="form-control" @bind="newProduct.Description" placeholder="Short description" />
                </div>
                <div class="col-md-4">
                    <label class="form-label fw-semibold">Price ($)</label>
                    <div class="input-group">
                        <span class="input-group-text">$</span>
                        <input type="number" class="form-control" @bind="newProduct.Price" step="0.01" min="0" />
                    </div>
                </div>
                <div class="col-md-4">
                    <label class="form-label fw-semibold">Stock</label>
                    <input type="number" class="form-control" @bind="newProduct.Stock" min="0" placeholder="0" />
                </div>
                <div class="col-md-4 d-flex align-items-end">
                    <button class="btn btn-primary w-100" @onclick="AddProduct" disabled="@isSaving">
                        @(isSaving ? "Saving..." : "💾 Save Product")
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@if (isLoading)
{
    <div class="text-center py-5">
        <div class="spinner-border text-primary mb-2"></div>
        <p class="text-muted">Loading products...</p>
    </div>
}
else if (!string.IsNullOrEmpty(loadError))
{
    <div class="alert alert-warning d-flex align-items-center gap-2">
        <span>⚠️</span><span>@loadError</span>
    </div>
}
else if (products.Count == 0)
{
    <div class="text-center py-5 text-muted">
        <div style="font-size:3rem">📦</div>
        <h5 class="mt-3">No products yet</h5>
        <p class="small">Click <strong>+ Add Product</strong> to add your first item.</p>
    </div>
}
else
{
    <div class="row row-cols-1 row-cols-md-3 g-4">
        @foreach (var p in products)
        {
            <div class="col">
                <ProductCard Product="p" />
            </div>
        }
    </div>
    <p class="text-muted small mt-3">Showing @products.Count product@(products.Count == 1 ? "" : "s")</p>
}

@code {
    private List<ProductDto> products = new();
    private CreateProductDto newProduct = new();
    private bool showForm, isLoading = true, isSaving, success;
    private string message = string.Empty;
    private string loadError = string.Empty;

    protected override async Task OnInitializedAsync() => await LoadProducts();

    private async Task LoadProducts()
    {
        isLoading = true; loadError = string.Empty;
        try { products = await ProductService.GetAllAsync(); }
        catch (Exception ex) { loadError = $"Could not load products: {ex.Message}"; }
        isLoading = false;
    }

    private void ToggleForm() { showForm = !showForm; message = string.Empty; }

    private async Task AddProduct()
    {
        if (string.IsNullOrWhiteSpace(newProduct.Name)) { message = "Name is required."; success = false; return; }
        isSaving = true; message = string.Empty;
        try
        {
            var ok = await ProductService.CreateAsync(newProduct);
            if (ok) { message = $"Product '{newProduct.Name}' added successfully!"; success = true; newProduct = new(); showForm = false; await LoadProducts(); }
            else { message = "Failed to add product. Please try again."; success = false; }
        }
        catch (Exception ex) { message = $"Error: {ex.Message}"; success = false; }
        isSaving = false;
    }
}
