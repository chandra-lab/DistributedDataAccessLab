@page "/dashboard"
<PageTitle>Dashboard</PageTitle>

<div class="text-center py-4">
    <h1 class="display-5 fw-bold">E-Commerce Microservices</h1>
    <p class="lead text-muted">Manage products, customers, and orders via the API Gateway.</p>
</div>

<div class="row g-4 justify-content-center mt-2">
    <div class="col-md-4">
        <div class="card shadow-sm h-100 border-0">
            <div class="card-body text-center">
                <div class="fs-1 mb-2">📦</div>
                <h5 class="card-title">Products</h5>
                <p class="card-text text-muted">View and add products to the catalog.</p>
                <a href="/products" class="btn btn-primary">Go to Products</a>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card shadow-sm h-100 border-0">
            <div class="card-body text-center">
                <div class="fs-1 mb-2">👤</div>
                <h5 class="card-title">Customers</h5>
                <p class="card-text text-muted">View and register new customers.</p>
                <a href="/customers" class="btn btn-primary">Go to Customers</a>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card shadow-sm h-100 border-0">
            <div class="card-body text-center">
                <div class="fs-1 mb-2">🧾</div>
                <h5 class="card-title">Orders</h5>
                <p class="card-text text-muted">Place and review customer orders.</p>
                <a href="/orders" class="btn btn-primary">Go to Orders</a>
            </div>
        </div>
    </div>
</div>
