@page "/dashboard"
<PageTitle>Dashboard</PageTitle>

<h2 class="fw-bold mb-4" style="color:#0f172a">Dashboard</h2>

<div class="row g-4">
    <div class="col-md-4">
        <div class="card border-0 shadow-sm h-100 text-center p-3">
            <div class="card-body">
                <div style="font-size:2.5rem"> 📦 </div>
                <h5 class="card-title fw-bold mt-2">Products</h5>
                <p class="card-text text-muted small">View and add products to the catalog.</p>
                <a href="/products" class="btn btn-primary mt-2">Go to Products</a>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card border-0 shadow-sm h-100 text-center p-3">
            <div class="card-body">
                <div style="font-size:2.5rem"> 👤 </div>
                <h5 class="card-title fw-bold mt-2">Customers</h5>
                <p class="card-text text-muted small">View and register new customers.</p>
                <a href="/customers" class="btn btn-primary mt-2">Go to Customers</a>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card border-0 shadow-sm h-100 text-center p-3">
            <div class="card-body">
                <div style="font-size:2.5rem"> 🧾 </div>
                <h5 class="card-title fw-bold mt-2">Orders</h5>
                <p class="card-text text-muted small">Place and review customer orders.</p>
                <a href="/orders" class="btn btn-primary mt-2">Go to Orders</a>
            </div>
        </div>
    </div>
</div>
