@page "/orders"
@inject BlazorFrontend.Services.OrderService OrderService
@inject BlazorFrontend.Services.CustomerService CustomerService
@inject BlazorFrontend.Services.ProductService ProductService
@using BlazorFrontend.Models
@using BlazorFrontend.Components

<PageTitle>Orders</PageTitle>

<div class="page-header">
    <h2>Orders</h2>
    <button class="btn btn-success" @onclick="ToggleForm">
        @(showForm ? "Cancel" : "+ Create Order")
    </button>
</div>

@if (showForm)
{
    <OrderForm Customers="customers" Products="products"
               OnSubmit="HandleCreateOrder" OnCancel="ToggleForm" IsSaving="isSaving" />
}

@if (!string.IsNullOrEmpty(message))
{
    <div class="alert @(success ? "alert-success" : "alert-danger") mb-3">@message</div>
}

@if (isLoading)
{
    <div class="text-center py-5"><div class="spinner-border text-primary"></div></div>
}
else if (!string.IsNullOrEmpty(loadError))
{
    <div class="alert alert-warning">@loadError</div>
}
else if (orders.Count == 0)
{
    <div class="alert alert-info">No orders yet. Create one above!</div>
}
else
{
    <div class="table-responsive">
        <table class="table table-hover table-bordered align-middle">
            <thead class="table-dark">
                <tr><th>ID</th><th>Customer ID</th><th>Product ID</th><th>Qty</th><th>Total</th><th>Status</th><th>Created</th></tr>
            </thead>
            <tbody>
                @foreach (var o in orders)
                {
                    <tr>
                        <td>@o.Id</td><td>@o.CustomerId</td><td>@o.ProductId</td>
                        <td>@o.Quantity</td><td>$@o.TotalPrice.ToString("F2")</td>
                        <td><span class="badge @StatusBadge(o.Status)">@o.Status</span></td>
                        <td>@o.CreatedAt.ToLocalTime().ToString("yyyy-MM-dd HH:mm")</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}

@code {
    private List<Order> orders = new();
    private List<Customer> customers = new();
    private List<Product> products = new();
    private bool showForm, isLoading = true, isSaving, success;
    private string message = string.Empty;
    private string loadError = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        isLoading = true; loadError = string.Empty;
        try
        {
            var t1 = OrderService.GetAllAsync();
            var t2 = CustomerService.GetAllAsync();
            var t3 = ProductService.GetAllAsync();
            await Task.WhenAll(t1, t2, t3);
            orders = t1.Result; customers = t2.Result; products = t3.Result;
        }
        catch (Exception ex) { loadError = $"Could not load data: {ex.Message}"; }
        isLoading = false;
    }

    private void ToggleForm() { showForm = !showForm; message = string.Empty; }

    private async Task HandleCreateOrder(CreateOrderRequest request)
    {
        isSaving = true;
        try
        {
            var ok = await OrderService.CreateAsync(request);
            if (ok) { message = $"Order placed! Total: ${request.TotalPrice:F2}"; success = true; showForm = false; orders = await OrderService.GetAllAsync(); }
            else { message = "Failed to create order."; success = false; }
        }
        catch (Exception ex) { message = $"Error: {ex.Message}"; success = false; }
        isSaving = false;
    }

    private static string StatusBadge(string status) => status switch
    {
        "Completed" => "bg-success",
        "Cancelled"  => "bg-danger",
        _            => "bg-warning text-dark"
    };
}
