@page "/customers"
@inject BlazorFrontend.Services.CustomerService CustomerService
@using BlazorFrontend.Models
@using BlazorFrontend.Components

<PageTitle>Customers</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h2 class="fw-bold mb-0" style="color:#0f172a">👤 Customers</h2>
        <p class="text-muted small mb-0">View and onboard customers</p>
    </div>
    <button class="btn @(showForm ? "btn-outline-secondary" : "btn-primary") px-4" @onclick="ToggleForm">
        @(showForm ? "✕ Cancel" : "+ Add Customer")
    </button>
</div>

@if (!string.IsNullOrEmpty(message))
{
    <div class="alert @(success ? "alert-success" : "alert-danger") alert-dismissible d-flex align-items-center gap-2 mb-4">
        <span>@(success ? "✅" : "❌")</span>
        <span>@message</span>
        <button type="button" class="btn-close ms-auto" @onclick="() => message = string.Empty"></button>
    </div>
}

@if (showForm)
{
    <CustomerForm OnSubmit="HandleAddCustomer" OnCancel="ToggleForm" IsSaving="isSaving" />
}

@if (isLoading)
{
    <div class="text-center py-5">
        <div class="spinner-border text-primary mb-2"></div>
        <p class="text-muted">Loading customers...</p>
    </div>
}
else if (!string.IsNullOrEmpty(loadError))
{
    <div class="alert alert-warning d-flex align-items-center gap-2">
        <span>⚠️</span><span>@loadError</span>
    </div>
}
else if (customers.Count == 0)
{
    <div class="text-center py-5 text-muted">
        <div style="font-size:3rem">👤</div>
        <h5 class="mt-3">No customers yet</h5>
        <p class="small">Click <strong>+ Add Customer</strong> to register your first customer.</p>
    </div>
}
else
{
    <div class="card border-0 shadow-sm">
        <div class="card-header border-0 d-flex justify-content-between align-items-center py-3" style="background:#f8fafc">
            <span class="fw-semibold text-muted small">@customers.Count customer@(customers.Count == 1 ? "" : "s") registered</span>
        </div>
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead style="background:#f1f5f9">
                    <tr>
                        <th class="ps-4 text-muted small fw-semibold" style="width:60px">#</th>
                        <th class="text-muted small fw-semibold">Name</th>
                        <th class="text-muted small fw-semibold">Email</th>
                        <th class="text-muted small fw-semibold pe-4">Phone</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var c in customers)
                    {
                        <tr>
                            <td class="ps-4">
                                <span class="badge bg-light text-muted border">@c.Id</span>
                            </td>
                            <td>
                                <div class="d-flex align-items-center gap-2">
                                    <div class="rounded-circle d-flex align-items-center justify-content-center text-white fw-bold"
                                         style="width:34px;height:34px;font-size:.8rem;background:linear-gradient(135deg,#6d28d9,#3b82f6);flex-shrink:0">
                                        @c.Name.Substring(0, 1).ToUpper()
                                    </div>
                                    <span class="fw-semibold">@c.Name</span>
                                </div>
                            </td>
                            <td class="text-muted">@c.Email</td>
                            <td class="pe-4 text-muted">@c.Phone</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}

@code {
    private List<Customer> customers = new();
    private bool showForm, isLoading = true, isSaving, success;
    private string message = string.Empty;
    private string loadError = string.Empty;

    protected override async Task OnInitializedAsync() => await LoadCustomers();

    private async Task LoadCustomers()
    {
        isLoading = true; loadError = string.Empty;
        try { customers = await CustomerService.GetAllAsync(); }
        catch (Exception ex) { loadError = $"Could not load customers: {ex.Message}"; }
        isLoading = false;
    }

    private void ToggleForm() { showForm = !showForm; message = string.Empty; }

    private async Task HandleAddCustomer(CreateCustomerRequest request)
    {
        isSaving = true;
        try
        {
            var ok = await CustomerService.CreateAsync(request);
            if (ok) { message = $"Customer '{request.Name}' added successfully!"; success = true; showForm = false; await LoadCustomers(); }
            else { message = "Failed to add customer. Please try again."; success = false; }
        }
        catch (Exception ex) { message = $"Error: {ex.Message}"; success = false; }
        isSaving = false;
    }
}
