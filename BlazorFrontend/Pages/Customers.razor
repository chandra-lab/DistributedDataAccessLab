@page "/customers"
@inject BlazorFrontend.Services.CustomerService CustomerService
@using BlazorFrontend.Models
@using BlazorFrontend.Components

<PageTitle>Customers</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>👤 Customers</h2>
    <button class="btn btn-success" @onclick="ToggleForm">
        @(showForm ? "Cancel" : "+ Add Customer")
    </button>
</div>

@* SMART LAYER delegates the form UI to the dumb CustomerForm component.
   CustomerForm fires OnSubmit with the data; this page performs the API call. *@
@if (showForm)
{
    <CustomerForm OnSubmit="HandleAddCustomer" OnCancel="ToggleForm" IsSaving="isSaving" />
}

@if (!string.IsNullOrEmpty(message))
{
    <div class="alert @(success ? "alert-success" : "alert-danger") mb-3">@message</div>
}

@if (isLoading)
{
    <div class="text-center py-5"><div class="spinner-border text-primary"></div></div>
}
else if (customers.Count == 0)
{
    <div class="alert alert-info">No customers found. Add one above!</div>
}
else
{
    <div class="table-responsive">
        <table class="table table-hover table-bordered align-middle">
            <thead class="table-dark">
                <tr><th>ID</th><th>Name</th><th>Email</th><th>Phone</th></tr>
            </thead>
            <tbody>
                @foreach (var c in customers)
                {
                    <tr>
                        <td>@c.Id</td>
                        <td>@c.Name</td>
                        <td>@c.Email</td>
                        <td>@c.Phone</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}

@code {
    // SMART LAYER: manages state and performs API calls.
    // The CustomerForm component only handles UI; it delegates submission here via EventCallback.
    private List<Customer> customers = new();
    private bool showForm = false;
    private bool isLoading = true;
    private bool isSaving = false;
    private bool success = false;
    private string message = string.Empty;

    protected override async Task OnInitializedAsync() => await LoadCustomers();

    private async Task LoadCustomers()
    {
        isLoading = true;
        customers = await CustomerService.GetAllAsync();
        isLoading = false;
    }

    private void ToggleForm() { showForm = !showForm; message = string.Empty; }

    /// <summary>
    /// Invoked by the CustomerForm component via EventCallback.
    /// This page is responsible for the actual API call.
    /// </summary>
    private async Task HandleAddCustomer(CreateCustomerRequest request)
    {
        isSaving = true;
        var ok = await CustomerService.CreateAsync(request);
        if (ok) { message = "Customer added successfully!"; success = true; showForm = false; await LoadCustomers(); }
        else    { message = "Failed to add customer. Check gateway connection."; success = false; }
        isSaving = false;
    }
}
