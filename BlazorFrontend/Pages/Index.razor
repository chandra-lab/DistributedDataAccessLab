@page "/"
<PageTitle>E-Commerce Admin - Home</PageTitle>

<!-- Hero -->
<div class="text-center py-5 mb-4" style="background:linear-gradient(135deg,#0f172a 0%,#1e3a5f 60%,#0f4c81 100%); border-radius:16px; color:#fff; padding: 3rem 2rem !important">
    <span class="badge mb-3 px-3 py-2" style="background:rgba(255,255,255,.15); font-size:.75rem; letter-spacing:.1em">
        🚀 CSCI 6844 - FINAL DELIVERABLE
    </span>
    <h1 class="display-5 fw-bold mb-3">Full-Stack E-Commerce<br/>Microservices System</h1>
    <p class="mb-4" style="color:rgba(255,255,255,.75); max-width:560px; margin:0 auto">
        A containerized distributed backend extended with a Blazor WebAssembly frontend,
        all communicating through an Ocelot API Gateway.
    </p>
    <div class="d-flex justify-content-center gap-3 flex-wrap">
        <a href="/products" class="btn btn-light fw-semibold px-4">📦 Products</a>
        <a href="/customers" class="btn btn-outline-light fw-semibold px-4">👤 Customers</a>
        <a href="/orders" class="btn btn-outline-light fw-semibold px-4">🧾 Orders</a>
        <a href="/dashboard" class="btn btn-outline-light fw-semibold px-4">📊 Dashboard</a>
    </div>
</div>

<!-- About the Project -->
<div class="mb-5">
    <h4 class="fw-bold mb-1" style="color:#0f172a">📋 About the Project</h4>
    <p class="text-muted small mb-4">Programming for the Internet · CSCI 6844 · April 2026</p>
    <div class="row g-4">
        <div class="col-md-6">
            <div class="card border-0 shadow-sm h-100 p-1">
                <div class="card-body">
                    <h6 class="fw-bold text-primary mb-3">🎯 What this project does</h6>
                    <p class="text-muted small mb-2">
                        This system extends an existing containerized e-commerce microservices backend
                        with a <strong>Blazor WebAssembly</strong> frontend. The frontend connects to four
                        independent microservices through a single API Gateway — never calling services directly.
                    </p>
                    <p class="text-muted small mb-0">
                        Orders trigger a <strong>RabbitMQ event</strong> that the NotificationService
                        consumes asynchronously, demonstrating real event-driven architecture.
                    </p>
                </div>
            </div>
        </div>
        <div class="col-md-6">
            <div class="card border-0 shadow-sm h-100 p-1">
                <div class="card-body">
                    <h6 class="fw-bold text-primary mb-3">🏗️ Architecture at a glance</h6>
                    <div class="d-flex flex-column gap-2 small">
                        @foreach (var (icon, label, desc) in ArchLayers)
                        {
                            <div class="d-flex align-items-start gap-2">
                                <span style="min-width:22px">@icon</span>
                                <div>
                                    <span class="fw-semibold">@label</span>
                                    <span class="text-muted"> — @desc</span>
                                </div>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Tech Stack -->
<div class="mb-5">
    <h4 class="fw-bold mb-1" style="color:#0f172a">🛠️ Technologies Used</h4>
    <p class="text-muted small mb-4">Every layer of the stack, from browser to database</p>
    <div class="row g-3">
        @foreach (var tech in TechStack)
        {
            <div class="col-6 col-md-4 col-lg-3">
                <div class="card border-0 h-100 text-center p-3" style="background:@tech.Bg; border-radius:12px">
                    <div style="font-size:1.8rem">@tech.Icon</div>
                    <div class="fw-bold small mt-2" style="color:@tech.Color">@tech.Name</div>
                    <div class="text-muted" style="font-size:.7rem; margin-top:2px">@tech.Role</div>
                </div>
            </div>
        }
    </div>
</div>

<!-- How it works -->
<div class="mb-5">
    <h4 class="fw-bold mb-1" style="color:#0f172a">⚡ How an Order Flows Through the System</h4>
    <p class="text-muted small mb-4">End-to-end from browser click to database record</p>
    <div class="row g-3">
        @foreach (var (n, title, desc, color) in OrderFlow)
        {
            <div class="col-md-3">
                <div class="card border-0 shadow-sm h-100">
                    <div class="card-body">
                        <div class="rounded-circle d-flex align-items-center justify-content-center fw-bold text-white mb-3"
                             style="width:36px;height:36px;background:@color;font-size:.9rem">@n</div>
                        <h6 class="fw-bold mb-1">@title</h6>
                        <p class="text-muted small mb-0">@desc</p>
                    </div>
                </div>
            </div>
        }
    </div>
</div>

<!-- Navigation Cards -->
<div class="mb-2">
    <h4 class="fw-bold mb-4" style="color:#0f172a">🔗 Navigate the System</h4>
    <div class="row g-4">
        <div class="col-md-4">
            <a href="/products" class="feature-card blue p-4">
                <div class="card-body">
                    <div style="font-size:2rem; margin-bottom:.75rem">📦</div>
                    <h5 class="card-title">Products</h5>
                    <p class="card-text small">Browse the catalog and add new products with pricing and stock levels.</p>
                    <div class="mt-3" style="font-size:.78rem; font-weight:700; text-transform:uppercase; letter-spacing:.08em; opacity:.8">
                        Go to Products →
                    </div>
                </div>
            </a>
        </div>
        <div class="col-md-4">
            <a href="/customers" class="feature-card purple p-4">
                <div class="card-body">
                    <div style="font-size:2rem; margin-bottom:.75rem">👤</div>
                    <h5 class="card-title">Customers</h5>
                    <p class="card-text small">View registered customers and onboard new ones with a single form.</p>
                    <div class="mt-3" style="font-size:.78rem; font-weight:700; text-transform:uppercase; letter-spacing:.08em; opacity:.8">
                        Go to Customers →
                    </div>
                </div>
            </a>
        </div>
        <div class="col-md-4">
            <a href="/orders" class="feature-card teal p-4">
                <div class="card-body">
                    <div style="font-size:2rem; margin-bottom:.75rem">🧾</div>
                    <h5 class="card-title">Orders</h5>
                    <p class="card-text small">Place new orders, track status, and watch RabbitMQ events fire in real time.</p>
                    <div class="mt-3" style="font-size:.78rem; font-weight:700; text-transform:uppercase; letter-spacing:.08em; opacity:.8">
                        Go to Orders →
                    </div>
                </div>
            </a>
        </div>
    </div>
</div>

@code {
    private static readonly (string Icon, string Label, string Desc)[] ArchLayers =
    [
        ("🌐", "Blazor WASM",         "Browser SPA served by nginx on port 5005"),
        ("🔀", "API Gateway (Ocelot)", "Single entry point — routes /api/* to services"),
        ("📦", "ProductService",       "Manages catalog — SQLite, port 5003"),
        ("👤", "CustomerService",      "Manages accounts — SQLite, port 5001"),
        ("🧾", "OrderService",         "Processes orders — SQLite + RabbitMQ publish"),
        ("🔔", "NotificationService",  "Consumes OrderCreated events from RabbitMQ"),
    ];

    private record TechItem(string Icon, string Name, string Role, string Bg, string Color);
    private static readonly TechItem[] TechStack =
    [
        new("⚡", ".NET 10",          "Runtime & SDK",         "#eff6ff", "#1d4ed8"),
        new("🖥️", "Blazor WASM",      "Frontend SPA",          "#f0fdf4", "#15803d"),
        new("🌐", "nginx",            "Static server & proxy", "#faf5ff", "#7c3aed"),
        new("🔀", "Ocelot",           "API Gateway",           "#fff7ed", "#c2410c"),
        new("🐰", "RabbitMQ",         "Message broker",        "#fef2f2", "#dc2626"),
        new("🐳", "Docker Compose",   "Orchestration",         "#eff6ff", "#1d4ed8"),
        new("🗃️", "SQLite",           "Per-service DB",        "#f8fafc", "#475569"),
        new("📡", "REST / JSON",      "API protocol",          "#f0fdf4", "#15803d"),
    ];

    private static readonly (int N, string Title, string Desc, string Color)[] OrderFlow =
    [
        (1, "Browser sends POST",    "Blazor calls /api/orders via nginx proxy to the API Gateway.", "#3b82f6"),
        (2, "Ocelot routes request", "Gateway matches the route and forwards to OrderService:8080.", "#8b5cf6"),
        (3, "Order persisted",       "OrderService validates, saves to SQLite, publishes OrderCreated to RabbitMQ.", "#0f766e"),
        (4, "Event consumed",        "NotificationService receives the message and logs the notification asynchronously.", "#f59e0b"),
    ];
}
