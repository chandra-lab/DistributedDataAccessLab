@page "/"
<PageTitle>E-Commerce Admin</PageTitle>

<div class="hero-section text-center mb-4">
    <span class="badge bg-primary bg-opacity-10 text-primary fw-bold mb-3 px-3 py-2" style="font-size:.8rem; letter-spacing:.06em">
        [*] MICROSERVICES PLATFORM
    </span>
    <h1 class="display-5 fw-bold" style="color:#0f172a; letter-spacing:-.02em">
        Manage your store<br/>in one place.
    </h1>
    <p class="lead text-muted mt-2">
        View and manage products, customers, and orders - all routed through the API Gateway.
    </p>
</div>

<div class="row g-4 justify-content-center">
    <div class="col-md-4">
        <a href="/products" class="feature-card blue p-4">
            <div class="card-body">
                <div style="font-size:2rem; margin-bottom:.75rem">[P]</div>
                <h5 class="card-title">Products</h5>
                <p class="card-text small">Browse the catalog and add new products with pricing and stock levels.</p>
                <div class="mt-3" style="font-size:.78rem; font-weight:700; text-transform:uppercase; letter-spacing:.08em; opacity:.8">
                    Go to Products ->
                </div>
            </div>
        </a>
    </div>
    <div class="col-md-4">
        <a href="/customers" class="feature-card purple p-4">
            <div class="card-body">
                <div style="font-size:2rem; margin-bottom:.75rem">[C]</div>
                <h5 class="card-title">Customers</h5>
                <p class="card-text small">View registered customers and onboard new ones with a single form.</p>
                <div class="mt-3" style="font-size:.78rem; font-weight:700; text-transform:uppercase; letter-spacing:.08em; opacity:.8">
                    Go to Customers ->
                </div>
            </div>
        </a>
    </div>
    <div class="col-md-4">
        <a href="/orders" class="feature-card teal p-4">
            <div class="card-body">
                <div style="font-size:2rem; margin-bottom:.75rem">[O]</div>
                <h5 class="card-title">Orders</h5>
                <p class="card-text small">Place new orders, track status, and watch RabbitMQ events fire in real time.</p>
                <div class="mt-3" style="font-size:.78rem; font-weight:700; text-transform:uppercase; letter-spacing:.08em; opacity:.8">
                    Go to Orders ->
                </div>
            </div>
        </a>
    </div>
</div>
