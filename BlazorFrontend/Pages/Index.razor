@page "/"
<PageTitle>E-Commerce Admin</PageTitle>

<div class="hero">
    <div class="hero-badge">[*] Microservices Platform</div>
    <h1>Manage your <span>store</span><br/>in one place.</h1>
    <p>View and manage products, customers, and orders - all routed through the API Gateway.</p>
</div>

<div class="feature-grid">
    <a href="/products" class="feature-card blue">
        <div class="feature-card-icon">[P]</div>
        <h3>Products</h3>
        <p>Browse the catalog and add new products with pricing and stock levels.</p>
        <div class="card-cta">Go to Products -></div>
    </a>

    <a href="/customers" class="feature-card purple">
        <div class="feature-card-icon">[C]</div>
        <h3>Customers</h3>
        <p>View registered customers and onboard new ones with a single form.</p>
        <div class="card-cta">Go to Customers -></div>
    </a>

    <a href="/orders" class="feature-card teal">
        <div class="feature-card-icon">[O]</div>
        <h3>Orders</h3>
        <p>Place new orders, track status, and watch RabbitMQ events fire in real time.</p>
        <div class="card-cta">Go to Orders -></div>
    </a>
</div>
